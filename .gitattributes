# .gitattributes - 统一 Git 行为

# ==================== 文本文件自动规范化 ====================
# 提交时转换为 LF，检出时保持 LF
* text=auto eol=lf

# ==================== Java ====================
*.java text diff=java
*.groovy text diff=java

# ==================== 配置文件 ====================
*.xml text diff=xml
*.properties text diff=properties
*.yml text diff=yaml
*.yaml text diff=yaml
*.json text diff=json
*.toml text
*.ini text
*.conf text

# ==================== Shell 脚本 ====================
*.sh text eol=lf
*.bash text eol=lf

# ==================== 文档 ====================
*.md text diff=markdown
*.txt text
*.adoc text

# ==================== Web 前端 ====================
*.js text
*.ts text
*.css text
*.scss text
*.html text
*.htm text
*.svg text

# ==================== 二进制文件（永不转换） ====================
*.jar binary
*.class binary
*.war binary
*.ear binary
*.zip binary
*.tar binary
*.tar.gz binary
*.tgz binary
*.gz binary
*.bz2 binary
*.xz binary
*.7z binary
*.rar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.webp binary
*.tif binary
*.tiff binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.mp3 binary
*.mp4 binary
*.avi binary
*.mov binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# ==================== 导出忽略（git archive 不包含） ====================
.gitattributes export-ignore
.gitignore export-ignore
checkstyle.xml export-ignore
checkstyle-suppressions.xml export-ignore
spotbugs-exclude.xml export-ignore
.editorconfig export-ignore
CONTRIBUTING.md export-ignore
