<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Zerx 项目 Checkstyle 规则
    基于 Google Java Style Guide 定制，适配项目编码规范
    
    执行方式：
    - Maven 验证阶段自动执行：mvn verify
    - 单独执行：mvn checkstyle:check
    - IDEA 插件：安装 Checkstyle-IDEA 插件，指向此文件
-->

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="localeLanguage" value="zh"/>
    <property name="localeCountry" value="CN"/>
    <property name="fileExtensions" value="java"/>

    <!-- ==================== 文件级检查 ==================== -->

    <!-- 文件长度不超过 2000 行 -->
    <module name="FileLength">
        <property name="max" value="2000"/>
    </module>

    <!-- 文件末尾必须有换行符（与 EditorConfig 配合） -->
    <module name="NewlineAtEndOfFile"/>

    <!-- 禁止 Tab 缩进 -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- 文件中不能有 Windows 换行符（CRLF） -->
    <module name="RegexpSingleline">
        <property name="format" value="\r"/>
        <property name="message" value="请使用 LF 换行符，不要使用 CRLF"/>
    </module>

    <!-- 行长度限制 -->
    <module name="LineLength">
        <property name="max" value="140"/>
        <property name="ignorePattern" value="^import.*|^\s*\*.*@|//.*$"/>
    </module>

    <!-- ==================== TreeWalker（代码结构检查） ==================== -->
    <module name="TreeWalker">

        <!-- ===== 命名规范 ===== -->

        <!-- 包名：全小写 -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- 类名：PascalCase，允许下划线前缀/后缀 -->
        <module name="TypeName">
            <property name="tokens" value="CLASS_DEF, INTERFACE_DEF, ENUM_DEF, ANNOTATION_DEF, RECORD_DEF"/>
            <message key="name.invalidPattern"
                     value="类名 ''{0}'' 必须使用 PascalCase 命名风格"/>
        </module>

        <!-- 方法名：camelCase -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-z0-9][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern"
                     value="方法名 ''{0}'' 必须使用 camelCase 命名风格"/>
        </module>

        <!-- 常量名：UPPER_SNAKE_CASE -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>

        <!-- 局部变量：camelCase -->
        <module name="LocalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 成员变量：camelCase -->
        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 参数名：camelCase -->
        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Lambda 参数：单个小写字母或 camelCase -->
        <module name="LambdaParameterName">
            <property name="format" value="^[a-z]([a-z0-9][a-zA-Z0-9]*)?$"/>
        </module>

        <!-- Catch 参数：小写字母 e -->
        <module name="CatchParameterName">
            <property name="format" value="^[a-z]([a-z0-9][a-zA-Z0-9]*)?$"/>
        </module>

        <!-- Pattern 变量：camelCase -->
        <module name="PatternVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- Record 组件：camelCase -->
        <module name="RecordComponentName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- ===== 导入规范 ===== -->

        <!-- 禁止使用 sun.* 包 -->
        <module name="IllegalImport">
            <property name="illegalPkgs" value="sun"/>
            <message key="import.illegal"
                     value="禁止导入 sun.* 包，请使用标准 JDK API"/>
        </module>

        <!-- 禁止使用通配符导入 -->
        <module name="AvoidStarImport">
            <message key="import.avoidStar"
                     value="禁止使用通配符导入 (如 import xxx.*)，请逐个导入类"/>
        </module>

        <!-- 禁止重复导入 -->
        <module name="RedundantImport"/>

        <!-- 禁止未使用的导入 -->
        <module name="UnusedImports"/>

        <!-- import 顺序：Java 标准库 > 第三方库 > 项目内部 -->
        <module name="ImportOrder">
            <property name="groups" value="java,javax,*,com.zerx"/>
            <property name="ordered" value="true"/>
            <property name="separated" value="true"/>
            <property name="staticGroups" value="java,javax,*,com.zerx"/>
            <property name="option" value="bottom"/>
        </module>

        <!-- ===== 代码结构 ===== -->

        <!-- 左花括号在同一行 -->
        <module name="LeftCurly">
            <property name="tokens"
                      value="ANNOTATION_DEF, CLASS_DEF, CTOR_DEF, ENUM_CONSTANT_DEF,
                             ENUM_DEF, INTERFACE_DEF, LAMBDA, LITERAL_CASE,
                             LITERAL_CATCH, LITERAL_DEFAULT, LITERAL_DO,
                             LITERAL_ELSE, LITERAL_FINALLY, LITERAL_FOR,
                             LITERAL_IF, LITERAL_SWITCH, LITERAL_SYNCHRONIZED,
                             LITERAL_TRY, LITERAL_WHILE, METHOD_DEF, OBJBLOCK,
                             STATIC_INIT, RECORD_DEF, COMPACT_CTOR_DEF"/>
        </module>

        <!-- 右花括号规则 -->
        <module name="RightCurly">
            <property name="id" value="RightCurlySame"/>
            <property name="tokens"
                      value="LITERAL_TRY, LITERAL_CATCH, LITERAL_FINALLY,
                             LITERAL_IF, LITERAL_ELSE"/>
        </module>
        <module name="RightCurly">
            <property name="id" value="RightCurlyAlone"/>
            <property name="option" value="alone"/>
            <property name="tokens"
                      value="CLASS_DEF, METHOD_DEF, CTOR_DEF, ENUM_DEF,
                             STATIC_INIT, INSTANCE_INIT, RECORD_DEF, COMPACT_CTOR_DEF"/>
        </module>



        <!-- 单行代码不能过长 -->
        <module name="MethodLength">
            <property name="max" value="80"/>
            <property name="countEmpty" value="false"/>
            <message key="maxLen.method"
                     value="方法长度不能超过 80 行，当前 {0} 行，请考虑拆分"/>
        </module>

        <!-- 参数个数不超过 8 个 -->
        <module name="ParameterNumber">
            <property name="max" value="8"/>
            <property name="tokens" value="METHOD_DEF, CTOR_DEF"/>
        </module>

        <!-- ===== 空白与格式 ===== -->

        <!-- 泛型空白 -->
        <module name="GenericWhitespace">
            <message key="ws.followed"
                     value="GenericWhitespace ''{0}'' 后应跟空白"/>
            <message key="ws.preceded"
                     value="GenericWhitespace ''{0}'' 前应有空白"/>
            <message key="ws.illegalFollow"
                     value="GenericWhitespace ''{0}'' 后不应跟空白 ''{1}''"/>
            <message key="ws.notPreceded"
                     value="GenericWhitespace ''{0}'' 前缺少空白"/>
        </module>


        <!-- ===== 编码实践 ===== -->

        <!-- 禁止空代码块 -->
        <module name="EmptyBlock">
            <property name="option" value="TEXT"/>
            <property name="tokens"
                      value="LITERAL_TRY, LITERAL_FINALLY, LITERAL_IF,
                             LITERAL_ELSE, LITERAL_SWITCH"/>
        </module>

        <!-- switch 必须有 default -->
        <module name="MissingSwitchDefault"/>

        <!-- fall-through 必须 @SuppressWarnings 或注释说明 -->
        <module name="FallThrough"/>

        <!-- long 常量必须大写 L -->
        <module name="UpperEll"/>

        <!-- 数组风格：Java 风格 String[] args，不要 C 风格 String args[] -->
        <module name="ArrayTypeStyle"/>

        <!-- equals 和 hashCode 必须同时重写 -->
        <module name="EqualsHashCode"/>

        <!-- 内联条件（三目运算符）简化 -->
        <module name="SimplifyBooleanExpression"/>

        <!-- 内联条件返回简化 -->
        <module name="SimplifyBooleanReturn"/>

        <!-- 字符串比较使用 equals，不要用 == -->
        <module name="StringLiteralEquality"/>

        <!-- ===== 注释规范 ===== -->

        <!-- 公共类/接口/枚举必须有 Javadoc -->
        <module name="MissingJavadocType">
            <property name="scope" value="public"/>
            <property name="tokens"
                      value="CLASS_DEF, INTERFACE_DEF, ENUM_DEF, ANNOTATION_DEF"/>
        </module>

        <!-- 公共方法必须有 Javadoc（允许 getter/setter/toString 等省略） -->
        <module name="MissingJavadocMethod">
            <property name="scope" value="public"/>
            <property name="minLineCount" value="3"/>
            <property name="allowedAnnotations" value="Override, Test, BeforeEach, AfterEach, BeforeAll, AfterAll, ParameterizedTest"/>
        </module>

        <!-- Javadoc 方法格式检查 -->
        <module name="JavadocMethod">
            <property name="accessModifiers" value="public, protected"/>
            <property name="allowMissingParamTags" value="true"/>
            <property name="allowMissingReturnTag" value="true"/>
        </module>

        <!-- ===== 修饰符 ===== -->

        <!-- 修饰符顺序 -->
        <module name="ModifierOrder"/>

        <!-- 红外修饰符检查（interface 中不需要 public/abstract） -->
        <module name="RedundantModifier"/>

        <!-- ===== 杂项 ===== -->

        <!-- 禁止使用 System.out / System.err（应使用日志框架） -->
        <module name="Regexp">
            <property name="format" value="System\.(out|err)\.print"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="禁止使用 System.out/System.err，请使用 SLF4J 日志框架"/>
        </module>

        <!-- 禁止使用 e.printStackTrace()（应使用日志框架） -->
        <module name="Regexp">
            <property name="format" value="\.printStackTrace\(\)"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="禁止使用 printStackTrace()，请使用日志框架记录异常"/>
        </module>

    </module>
</module>
