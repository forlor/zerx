<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.zerx</groupId>
    <artifactId>zerx-parent</artifactId>
    <version>${zerx.version}</version>
    <packaging>pom</packaging>
    <name>Zerx Parent</name>
    <description>Zerx - 面向企业级 Java 应用开发的多模块 Maven 脚手架</description>

    <modules>
        <module>zerx-core</module>
        <module>zerx-spring</module>
        <module>zerx-component</module>
    </modules>

    <properties>
        <zerx.version>1.0.0</zerx.version>
        <java.version>21</java.version>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

        <!-- Spring Boot -->
        <spring-boot.version>3.3.5</spring-boot.version>

        <!-- 依赖版本 -->
        <junit.version>5.10.3</junit.version>
        <slf4j.version>2.0.13</slf4j.version>
        <archunit.version>1.3.0</archunit.version>

        <!-- Spring 生态第三方库版本 -->
        <springdoc.version>2.6.0</springdoc.version>
        <jjwt.version>0.12.6</jjwt.version>
        <caffeine.version>3.1.8</caffeine.version>
        <redisson.version>3.35.0</redisson.version>
        <easyexcel.version>4.0.3</easyexcel.version>
        <bucket4j.version>8.7.0</bucket4j.version>
        <resilience4j.version>2.2.0</resilience4j.version>
        <micrometer.version>1.13.0</micrometer.version>

        <!-- OSS 组件第三方库版本 -->
        <minio.version>8.5.13</minio.version>
        <aliyun-oss.version>3.18.1</aliyun-oss.version>
        <cos-sdk.version>5.6.227</cos-sdk.version>
        <aws-s3.version>1.12.772</aws-s3.version>

        <!-- 插件版本 -->
        <maven-checkstyle-plugin.version>3.3.1</maven-checkstyle-plugin.version>
        <maven-spotbugs-plugin.version>4.8.5.0</maven-spotbugs-plugin.version>
        <maven-enforcer-plugin.version>3.4.1</maven-enforcer-plugin.version>
        <spotbugs.version>4.8.6</spotbugs.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- ======================== Spring Boot BOM ======================== -->
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-dependencies</artifactId>
                <version>${spring-boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- ======================== Zerx 内部模块 ======================== -->
            <dependency>
                <groupId>com.zerx</groupId>
                <artifactId>zerx-common</artifactId>
                <version>${zerx.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zerx</groupId>
                <artifactId>zerx-spring-web</artifactId>
                <version>${zerx.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zerx</groupId>
                <artifactId>zerx-spring-data</artifactId>
                <version>${zerx.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zerx</groupId>
                <artifactId>zerx-spring-cache-api</artifactId>
                <version>${zerx.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zerx</groupId>
                <artifactId>zerx-spring-cache-impl</artifactId>
                <version>${zerx.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zerx</groupId>
                <artifactId>zerx-spring-security-api</artifactId>
                <version>${zerx.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zerx</groupId>
                <artifactId>zerx-spring-security-impl</artifactId>
                <version>${zerx.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zerx</groupId>
                <artifactId>zerx-spring-logging</artifactId>
                <version>${zerx.version}</version>
            </dependency>
            <dependency>
                <groupId>com.zerx</groupId>
                <artifactId>zerx-component-oss</artifactId>
                <version>${zerx.version}</version>
            </dependency>

            <!-- 单元测试 -->
            <dependency>
                <groupId>org.junit.jupiter</groupId>
                <artifactId>junit-jupiter</artifactId>
                <version>${junit.version}</version>
                <scope>test</scope>
            </dependency>

            <!-- 日志 -->
            <dependency>
                <groupId>org.slf4j</groupId>
                <artifactId>slf4j-api</artifactId>
                <version>${slf4j.version}</version>
            </dependency>

            <!-- 架构测试 -->
            <dependency>
                <groupId>com.tngtech.archunit</groupId>
                <artifactId>archunit</artifactId>
                <version>${archunit.version}</version>
                <scope>test</scope>
            </dependency>
            <dependency>
                <groupId>com.tngtech.archunit</groupId>
                <artifactId>archunit-junit5</artifactId>
                <version>${archunit.version}</version>
                <scope>test</scope>
            </dependency>

            <!-- Zerx 内部模块 -->
            <dependency>
                <groupId>com.zerx</groupId>
                <artifactId>zerx-architecture-test</artifactId>
                <version>${zerx.version}</version>
                <type>test-jar</type>
                <scope>test</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>3.13.0</version>
                    <configuration>
                        <source>${java.version}</source>
                        <target>${java.version}</target>
                        <encoding>UTF-8</encoding>
                        <compilerArgs>
                            <arg>--enable-preview</arg>
                        </compilerArgs>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <version>3.2.5</version>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-source-plugin</artifactId>
                    <version>3.3.1</version>
                </plugin>

                <!-- Checkstyle 代码风格检查 -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-checkstyle-plugin</artifactId>
                    <version>${maven-checkstyle-plugin.version}</version>
                    <dependencies>
                        <dependency>
                            <groupId>com.puppycrawl.tools</groupId>
                            <artifactId>checkstyle</artifactId>
                            <version>10.15.0</version>
                        </dependency>
                    </dependencies>
                    <configuration>
                        <configLocation>checkstyle.xml</configLocation>
                        <suppressionsLocation>checkstyle-suppressions.xml</suppressionsLocation>
                        <consoleOutput>true</consoleOutput>
                        <failOnViolation>true</failOnViolation>
                        <violationSeverity>warning</violationSeverity>
                        <includeTestSourceDirectory>true</includeTestSourceDirectory>
                        <encoding>UTF-8</encoding>
                    </configuration>
                    <executions>
                        <execution>
                            <id>checkstyle-check</id>
                            <phase>validate</phase>
                            <goals>
                                <goal>check</goal>
                            </goals>
                        </execution>
                    </executions>
                </plugin>

                <!-- SpotBugs 静态代码分析 -->
                <plugin>
                    <groupId>com.github.spotbugs</groupId>
                    <artifactId>spotbugs-maven-plugin</artifactId>
                    <version>${maven-spotbugs-plugin.version}</version>
                    <dependencies>
                        <dependency>
                            <groupId>com.github.spotbugs</groupId>
                            <artifactId>spotbugs</artifactId>
                            <version>${spotbugs.version}</version>
                        </dependency>
                    </dependencies>
                    <configuration>
                        <effort>Max</effort>
                        <threshold>Medium</threshold>
                        <xmlOutput>true</xmlOutput>
                        <excludeFilterFile>spotbugs-exclude.xml</excludeFilterFile>
                        <includeTests>true</includeTests>
                    </configuration>
                    <executions>
                        <execution>
                            <id>spotbugs-check</id>
                            <phase>verify</phase>
                            <goals>
                                <goal>check</goal>
                            </goals>
                        </execution>
                    </executions>
                </plugin>
            </plugins>
        </pluginManagement>

        <!-- 全局绑定的插件（所有模块生效） -->
        <plugins>
            <!-- Maven Enforcer 构建约束 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-enforcer-plugin</artifactId>
                <version>${maven-enforcer-plugin.version}</version>
                <dependencies>
                    <!-- BanDuplicateClasses 规则需要 extra-enforcer-rules -->
                    <dependency>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>extra-enforcer-rules</artifactId>
                        <version>1.8.0</version>
                    </dependency>
                </dependencies>
                <executions>
                    <execution>
                        <id>enforce-rules</id>
                        <goals>
                            <goal>enforce</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <!-- 强制 JDK 版本 -->
                                <requireJavaVersion>
                                    <version>[21,)</version>
                                    <message>本项目需要 JDK 21 或更高版本</message>
                                </requireJavaVersion>

                                <!-- 强制 Maven 版本 -->
                                <requireMavenVersion>
                                    <version>[3.9.0,)</version>
                                    <message>本项目需要 Maven 3.9.0 或更高版本</message>
                                </requireMavenVersion>

                                <!-- 禁止依赖冲突 -->
                                <banDuplicatePomDependencyVersions/>

                                <!-- 禁止快照依赖（release 阶段） -->
                                <requireReleaseDeps>
                                    <message>发布版本不允许使用 SNAPSHOT 依赖</message>
                                    <onlyWhenRelease>true</onlyWhenRelease>
                                </requireReleaseDeps>

                                <!-- 禁止重复类（需要 extra-enforcer-rules） -->
                                <banDuplicateClasses>
                                    <findAllDuplicates>true</findAllDuplicates>
                                </banDuplicateClasses>

                                <!-- 确保多模块项目的关系正确 -->
                                <reactorModuleConvergence/>
                            </rules>
                            <fail>true</fail>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
