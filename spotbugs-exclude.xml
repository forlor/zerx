<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs 排除规则
    对已知合理的代码模式排除误报
-->

<FindBugsFilter>

    <!-- 排除测试代码 -->
    <Match>
        <Class name="~.*Test"/>
    </Match>

    <!-- 工具类中的静态方法返回null是合理的（如空集合场景） -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH"/>
        <Source name="~.*util/.*"/>
    </Match>

    <!-- 序列化相关：DTO/VO 类实现 Serializable 但可能没有 serialVersionUID -->
    <Match>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>

    <!-- equals/hashCode 对比常量时的优先级问题（null-safe 写法） -->
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK"/>
    </Match>

    <!-- 工具类构造函数可见性（工具类通过私有构造阻止实例化） -->
    <Match>
        <Bug pattern="UMAC_UNCALLABLE_METHOD_OF_ANONYMOUS_CLASS"/>
    </Match>

</FindBugsFilter>
